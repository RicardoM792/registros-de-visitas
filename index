<script>
const URL_MAESTRO_OFICINAS_CSV = "https://docs.google.com/spreadsheets/d/e/2PACX-1vTytGtmX-qgf-IxYpKiulo8iRIsJ6iTMgw70cbwQclOHuU5pS2MDKgwPqjMjgDuXzpaulDnLdcRdS5u/pub?gid=1309200962&single=true&output=csv";
const SUPABASE_URL = "https://lzsluzquoksiheyxcior.supabase.co";
const SUPABASE_ANON_KEY = "sb_publishable_frToEsE65PivRXN83cIckw_S0snLVgv";

let FUNCIONARIOS = { Mapfre: [], Colmena: [] };

async function cargarFuncionarios(){
  try{
    const resp = await fetch(SUPABASE_URL + '/rest/v1/funcionarios?select=nombre,aseguradora&activo=eq.true', {
      headers: {
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
      }
    });
    const data = await resp.json();
    FUNCIONARIOS = { Mapfre: [], Colmena: [] };
    data.forEach(f => FUNCIONARIOS[f.aseguradora].push(f.nombre));
  }catch(e){
    debugLog('Error cargando funcionarios: ' + e, 'err');
  }
}

let OFICINAS = [];
let oficinaSel = null;
let asegSel = null;
let SESSION = null;
let ofActiveIdx = -1;
let calFecha = new Date();
let visitasCache = [];
let filtroActivo = 'todos';
let diaSeleccionado = null;
let fpFecha = null;
let fechaConfirmada = null;
function obtenerFechaHoyStr(){
  const h = new Date();
  return h.getFullYear()+'-'+String(h.getMonth()+1).padStart(2,'0')+'-'+String(h.getDate()).padStart(2,'0');
}
function confirmarFechaPasada(fechaStr){
  return new Promise(resolve=>{
    const overlay = $('confirm-fecha-overlay');
    const fechaObj = new Date(fechaStr + 'T00:00:00');
    $('confirm-fecha-texto').textContent = fechaObj.toLocaleDateString('es-ES', {day:'numeric',month:'long',year:'numeric'});
    overlay.classList.add('show');
    const btnSi = $('confirm-fecha-si'), btnNo = $('confirm-fecha-no');
    function limpiar(){ overlay.classList.remove('show'); btnSi.removeEventListener('click', onSi); btnNo.removeEventListener('click', onNo); }
    function onSi(){ limpiar(); resolve(true); }
    function onNo(){ limpiar(); resolve(false); }
    btnSi.addEventListener('click', onSi);
    btnNo.addEventListener('click', onNo);
  });
}

function $(id){ return document.getElementById(id); }
function debugLog(msg, type) { console.log(`[${type}] ${msg}`); }

function clearError(id){
  const inp = $(id);
  const err = $('err-'+id.replace('f-','').replace('of-search','oficina'));
  if(inp) inp.classList.remove('err-field');
  if(err) err.classList.remove('show');
}
function clearAllErrors(){
  document.querySelectorAll('.err-field').forEach(el=>el.classList.remove('err-field'));
  document.querySelectorAll('.err-msg.show').forEach(el=>el.classList.remove('show'));
}
function showToast(msg, isError){
  const t = $('toast');
  t.textContent = msg;
  t.className = 'toast show' + (isError ? ' error' : '');
  setTimeout(()=>{ t.className = 'toast'; }, 3500);
}
function mostrarExito(){
  const o = $('success-overlay');
  o.classList.add('show');
  setTimeout(()=>o.classList.remove('show'), 1100);
}
function normTxt(s){
  return String(s||'').toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').trim();
}
function obtenerSaludo(){
  const h = new Date().getHours();
  if(h >= 5 && h < 12) return 'Buenos días';
  if(h >= 12 && h < 19) return 'Buenas tardes';
  return 'Buenas noches';
}

function pickAseg(aseg){
  asegSel = aseg;
  $('pill-m').className = 'aseg-pill' + (aseg==='Mapfre' ? ' sel-m' : '');
  $('pill-c').className = 'aseg-pill' + (aseg==='Colmena' ? ' sel-c' : '');
  $('err-aseg').classList.remove('show');
  const sel = $('l-func');
  sel.innerHTML = '<option value="">Seleccionar...</option>' +
    FUNCIONARIOS[aseg].map(n => `<option value="${n}">${n}</option>`).join('');
}

function doLogin(){
  let ok = true;
  if(!asegSel){ $('err-aseg').classList.add('show'); ok = false; }
  if(!$('l-func').value){ $('err-lfunc').classList.add('show'); ok = false; } else { $('err-lfunc').classList.remove('show'); }
  if(!ok) return;
  SESSION = { aseg: asegSel, func: $('l-func').value };
  localStorage.setItem('rv_session', JSON.stringify(SESSION));
  mostrarFormulario();
}

function mostrarFormulario(){
  $('card-login').className = 'card hidden';
  $('card-form').className = 'card';
  const primerNombre = SESSION.func.split(' ')[0];
  const nombreCapitalizado = primerNombre.charAt(0) + primerNombre.slice(1).toLowerCase();
  $('saludo-nombre').textContent = nombreCapitalizado;
  $('saludo-mensaje').textContent = obtenerSaludo() + ', listo para registrar tu visita';
  actualizarProgreso();
}

function cambiarUsuario(){
  SESSION = null;
  localStorage.removeItem('rv_session');
  asegSel = null;
  $('pill-m').className = 'aseg-pill';
  $('pill-c').className = 'aseg-pill';
  $('l-func').innerHTML = '<option value="">Selecciona aseguradora primero...</option>';
  limpiarFormulario();
  clearAllErrors();
  $('card-form').className = 'card hidden';
  $('card-login').className = 'card';
  ocultarCalendario();
}

function cargarOficinas(){
  Papa.parse(URL_MAESTRO_OFICINAS_CSV, {
    download: true,
    header: true,
    skipEmptyLines: true,
    complete: function(res){
      OFICINAS = res.data.map(r => ({
        oficina: (r['Nombre Oficina']||r['#Oficina']||'').trim(),
        codOficina: (r['Cód. Oficina']||'').trim(),
        codDane: (r['Cód. DANE']||'').trim(),
        codDaneCab: (r['Cód. DANE Cabecera Municipal']||'').trim(),
        codPostal: (r['Código Postal Oficinas']||'').trim(),
        categoria: (r['Categoría']||'').trim(),
        municipio: (r['Municipio']||'').trim(),
        departamento: (r['Departamento']||'').trim(),
        jefatura: (r['Jefaturas  Operaciones Regional']||r['Jefaturas Operaciones Regional']||'').trim(),
        gerenciaZonal: (r['Gerencia Zonal']||'').trim(),
        gerenciaRegional: (r['Gerencia Regional']||'').trim(),
        tipoHorario: (r['Tipo de Horario Vigente']||'').trim(),
        diasApertura: (r['Días de apertura']||'').trim(),
        horarioAtencion: (r['Horario Atención']||'').trim(),
        diasCierre: (r['Días de cierre']||'').trim(),
        direccion: (r['Dirección']||'').trim(),
        telefono: (r['Teléfono']||'').trim(),
        extensiones: (r['Extensiones']||'').trim(),
        tipologia: (r['Tipología Comercial']||'').trim(),
        competenciaBancaria: (r['* Competencia Bancaria']||r['Competencia Bancaria']||'').trim(),
        modalidadTransporte: (r['* Modalidad Transporte de Efectivo\n(Según contrato)']||r['Modalidad Transporte de Efectivo']||'').trim()
      })).filter(o => o.oficina);
      $('status-line').textContent = OFICINAS.length + ' oficinas cargadas';
      poblarRegionales();
      poblarComercialesOperativos();
    },
    error: function(err){
      $('status-line').textContent = 'No se pudo cargar la base de oficinas. Avisa al administrador.';
      debugLog('Error al cargar oficinas: ' + err, 'err');
    }
  });
}

function poblarRegionales(regionalSel, zonalSel){
  const regionales = [...new Set(OFICINAS.map(o => o.gerenciaRegional).filter(Boolean))].sort();
  const selReg = $('f-regional2');
  selReg.innerHTML = '<option value="">Seleccionar...</option>' + regionales.map(r => `<option${r===regionalSel?' selected':''}>${r}</option>`).join('');
  onRegionalChange(zonalSel);
}

function onRegionalChange(zonalSel){
  clearError('f-regional2');
  const regional = $('f-regional2').value;
  const selZon = $('f-zonal2');
  if(!regional){
    selZon.innerHTML = '<option value="">Selecciona regional primero...</option>';
    selZon.disabled = true;
    $('of-search').disabled = true;
    $('of-search').placeholder = 'Selecciona regional y zonal primero...';
    limpiarOficinaSiNoCoincide();
    actualizarProgreso();
    return;
  }
  const zonales = [...new Set(OFICINAS.filter(o => o.gerenciaRegional === regional).map(o => o.gerenciaZonal).filter(Boolean))].sort();
  selZon.innerHTML = '<option value="">Seleccionar...</option>' + zonales.map(z => `<option${z===zonalSel?' selected':''}>${z}</option>`).join('');
  selZon.disabled = false;
  $('of-search').disabled = true;
  $('of-search').placeholder = 'Selecciona zonal primero...';
  limpiarOficinaSiNoCoincide();
  if(zonalSel){ onZonalChange(); }
  actualizarProgreso();
}

function onZonalChange(){
  clearError('f-zonal2');
  const zonal = $('f-zonal2').value;
  if(!zonal){
    $('of-search').disabled = true;
    $('of-search').placeholder = 'Selecciona zonal primero...';
    limpiarOficinaSiNoCoincide();
    actualizarProgreso();
    return;
  }
  if(!oficinaSel){
    $('of-search').disabled = false;
    $('of-search').placeholder = 'Escribe ciudad o nombre de oficina...';
    setTimeout(()=>buscarOficina(true), 30);
  }
  limpiarOficinaSiNoCoincide();
  actualizarProgreso();
}

function limpiarOficinaSiNoCoincide(){
  if(oficinaSel){
    const regional = $('f-regional2').value;
    const zonal = $('f-zonal2').value;
    if((regional && oficinaSel.gerenciaRegional !== regional) || (zonal && oficinaSel.gerenciaZonal !== zonal)){
      oficinaSel = null;
      $('of-search').value = '';
      $('sel-card').className = 'sel-card';
      $('btn-cambiar-oficina').className = 'btn-mini-red hidden';
    }
  }
}

function poblarComercialesOperativos(){
  ['f-com','f-ope'].forEach(id=>{
    $(id).addEventListener('input', function(){ validarNumEntrada(id); });
  });
}

function ajustarNum(id, delta){
  let v = parseInt($(id).value || '0', 10);
  if(isNaN(v)) v = 0;
  v += delta;
  if(v < 0) v = 0;
  const modalidad = document.getElementById('f-modal').value;
  const limite = modalidad === 'Virtual' ? 100 : 20;
  if(v > limite) v = limite;
  $(id).value = v === 0 ? '' : String(v);
  validarNumEntrada(id);
}

function validarNumEntrada(id){
  const el = $(id);
  let v = el.value.replace(/\D/g,'');
  if(v.length > 3) v = v.slice(0,3);
  el.value = v;
  const errId = 'err-' + id.replace('f-','');
  const num = v === '' ? null : parseInt(v,10);
  const modalidad = document.getElementById('f-modal').value;
  const limite = modalidad === 'Virtual' ? 100 : 20;
  if(num !== null && (num > limite || num < 1)){
    el.classList.add('err-field');
    $(errId).classList.add('show');
  } else {
    el.classList.remove('err-field');
    $(errId).classList.remove('show');
  }
}

function campoNumValido(id){
  const v = $(id).value.trim();
  if(v === '') return true;
  const num = parseInt(v,10);
  const modalidad = document.getElementById('f-modal').value;
  const limite = modalidad === 'Virtual' ? 100 : 20;
  
  return !isNaN(num) && num >= 1 && num <= limite && v.length <= 3;
}

function buscarOficina(reabrir){
  const box = $('of-results');
  const regional = $('f-regional2').value;
  const zonal = $('f-zonal2').value;
  ofActiveIdx = -1;
  if(!zonal){ box.className='of-results'; box.innerHTML=''; return; }
  const q = reabrir ? '' : normTxt($('of-search').value);
  let pool = OFICINAS.filter(o =>
    (!regional || o.gerenciaRegional === regional) &&
    (!zonal || o.gerenciaZonal === zonal)
  );
  if(q.length >= 2){
    pool = pool.filter(o =>
      normTxt(o.oficina).includes(q) ||
      normTxt(o.municipio).includes(q) ||
      normTxt(o.codOficina).includes(q)
    );
  }
  const found = pool.slice(0,20);
  if(!found.length){
    box.innerHTML = '<div class="of-count">Sin resultados</div>';
    box.className='of-results show';
    return;
  }
  const header = `<div class="of-count">${found.length} oficina${found.length===1?'':'s'} encontrada${found.length===1?'':'s'}</div>`;
  box.innerHTML = header + found.map((o, i) => {
    const idx = OFICINAS.indexOf(o);
    return `<div class="of-opt" data-pos="${i}" onclick="selOficina(${idx})">
      <div class="of-opt-name">${o.oficina}</div>
      <div class="of-opt-meta">${o.municipio||''} · ${o.gerenciaRegional||''} · ${o.gerenciaZonal||''}</div>
    </div>`;
  }).join('');
  box.className = 'of-results show';
}

function resaltarOpt(opts){
  opts.forEach(o=>o.classList.remove('active'));
  if(opts[ofActiveIdx]){
    opts[ofActiveIdx].classList.add('active');
    opts[ofActiveIdx].scrollIntoView({block:'nearest'});
  }
}

function selOficina(idx){
  oficinaSel = OFICINAS[idx];
  $('of-search').value = oficinaSel.oficina;
  $('of-search').disabled = true;
  $('of-results').className = 'of-results';
  poblarRegionales(oficinaSel.gerenciaRegional, oficinaSel.gerenciaZonal);
  mostrarTarjetaOficina(oficinaSel);
  $('btn-cambiar-oficina').className = 'btn-mini-red';
  clearError('of-search');
  actualizarProgreso();
}

function cambiarOficina(e){
  if(e){ e.preventDefault(); e.stopPropagation(); }
  oficinaSel = null;
  $('of-search').value = '';
  $('of-search').disabled = false;
  $('of-search').placeholder = 'Escribe ciudad o nombre de oficina...';
  $('sel-card').className = 'sel-card';
  $('btn-cambiar-oficina').className = 'btn-mini-red hidden';
  $('of-search').focus();
  buscarOficina(true);
  actualizarProgreso();
}

function mostrarTarjetaOficina(o){
  const sc = $('sel-card');
  const nombre = `<i class="ti ti-building"></i> ${o.oficina}` + (o.categoria ? `<span class="osc-cat">${o.categoria}</span>` : '');
  const dir = o.direccion ? `<div class="osc-dir"><i class="ti ti-location"></i> ${o.direccion}</div>` : '';
  const chips = [
    (o.municipio || o.departamento) && `<span class="of-chip"><i class="ti ti-map-pin"></i> ${[o.municipio,o.departamento].filter(Boolean).join(', ')}</span>`,
    o.gerenciaRegional && `<span class="of-chip"><i class="ti ti-map"></i> ${o.gerenciaRegional}</span>`,
    o.gerenciaZonal && `<span class="of-chip"><i class="ti ti-layers"></i> ${o.gerenciaZonal}</span>`,
    o.horarioAtencion && `<span class="of-chip"><i class="ti ti-clock"></i> ${o.horarioAtencion}</span>`,
    o.telefono && `<span class="of-chip"><i class="ti ti-phone"></i> ${o.telefono}</span>`,
    o.diasApertura && `<span class="of-chip"><i class="ti ti-calendar-check"></i> ${o.diasApertura}</span>`,
    o.diasCierre && `<span class="of-chip"><i class="ti ti-calendar-off"></i> ${o.diasCierre}</span>`,
    o.codOficina && `<span class="of-chip"><i class="ti ti-building-bank"></i> Sban: ${o.codOficina}</span>`,
    o.tipologia && `<span class="of-chip"><i class="ti ti-tag"></i> ${o.tipologia}</span>`,
    o.modalidadTransporte && `<span class="of-chip"><i class="ti ti-truck"></i> ${o.modalidadTransporte}</span>`
  ].filter(Boolean).join('');
  sc.innerHTML = `<div class="osc-name">${nombre}</div>${dir}<div class="osc-chips">${chips}</div>`;
  sc.className = 'sel-card show';
}

function validar(){
  let ok = true;
  function marcarError(inputId, errId){
    $(inputId).classList.add('err-field');
    $(errId).classList.add('show');
    ok = false;
  }
  if(!oficinaSel) marcarError('of-search','err-oficina'); else clearError('of-search');
  if(!$('f-regional2').value) marcarError('f-regional2','err-regional'); else clearError('f-regional2');
  if(!$('f-zonal2').value) marcarError('f-zonal2','err-zonal'); else clearError('f-zonal2');
  if(!$('f-fecha').value.trim()) marcarError('f-fecha','err-fecha'); else clearError('f-fecha');
  if(!$('f-modal').value) marcarError('f-modal','err-modal'); else clearError('f-modal');
  if(!$('f-obj').value) marcarError('f-obj','err-obj'); else clearError('f-obj');
  if(!campoNumValido('f-com')) marcarError('f-com','err-com'); else clearError('f-com');
  if(!campoNumValido('f-ope')) marcarError('f-ope','err-ope'); else clearError('f-ope');
  return ok;
}

function actualizarProgreso(){
  const campos = [
    !!oficinaSel,
    !!$('f-regional2') && !!$('f-regional2').value,
    !!$('f-zonal2') && !!$('f-zonal2').value,
    !!$('f-fecha') && !!$('f-fecha').value.trim(),
    !!$('f-modal') && !!$('f-modal').value,
    !!$('f-obj') && !!$('f-obj').value
  ];
  const completados = campos.filter(Boolean).length;
  const pct = Math.round(completados / campos.length * 100);
  const fill = $('progress-fill');
  const label = $('progress-label');
  if(!fill || !label) return;
  fill.style.width = pct + '%';
  fill.style.background = pct === 100
    ? 'linear-gradient(90deg,var(--ok),#15803d)'
    : 'linear-gradient(90deg,var(--brand),var(--brand-d))';
  label.textContent = pct === 100 ? '¡Todo listo! 100%' : pct + '% completado';
}

async function enviarYConfirmar(payload) {
  debugLog('Enviando datos a Supabase via RPC...', 'info');
  try {
    const resp = await fetch(SUPABASE_URL + '/rest/v1/rpc/insertar_visita', {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        p_funcionario: payload.funcionario,
        p_aseguradora: payload.aseguradora,
        p_estado: payload.estado || 'Realizada',
        p_fecha: payload.fecha,
        p_hora_registro: payload.horaRegistro,
        p_modalidad: payload.modalidad,
        p_objetivo: payload.objetivo,
        p_comerciales: payload.comerciales || '',
        p_operativos: payload.operativos || '',
        p_oficina: payload.oficina,
        p_cod_oficina: payload.codOficina || '',
        p_gerencia_regional: payload.gerenciaRegional,
        p_gerencia_zonal: payload.gerenciaZonal
      })
    });
    const responseText = await resp.text();
    debugLog('Respuesta HTTP ' + resp.status + ': ' + responseText, 'info');
    if (!resp.ok) {
      let errorMsg = responseText;
      try {
        const errorJson = JSON.parse(responseText);
        if (errorJson.message) errorMsg = errorJson.message;
      } catch (e) {}
      debugLog('Supabase respondió con error ' + resp.status + ': ' + errorMsg, 'err');
      return { ok: false, error: 'Error ' + resp.status + ': ' + errorMsg };
    }
    const id = JSON.parse(responseText);
    debugLog('Guardado en Supabase, id: ' + id, 'ok');
    return { ok: true, id: id };
  } catch (err) {
    debugLog('Fallo de red: ' + (err.message || err), 'err');
    return { ok: false, error: err.message || String(err) };
  }
}

function obtenerMensajeExito(fecha) {
  const hoy = new Date();
  hoy.setHours(0,0,0,0);
  const fechaVisita = new Date(fecha + 'T00:00:00');
  fechaVisita.setHours(0,0,0,0);
  
  const diffDias = Math.round((fechaVisita - hoy) / (1000*60*60*24));
  
  if (diffDias === 0) {
    return '✓ Tu visita de hoy ha sido registrada';
  } else if (diffDias === 1) {
    return '✓ Tu visita de mañana ha sido registrada';
  } else if (diffDias === -1) {
    return '✓ Tu visita de ayer ha sido registrada';
  } else {
    const opciones = { day: 'numeric', month: 'long', year: 'numeric' };
    const fechaFormateada = fechaVisita.toLocaleDateString('es-ES', opciones);
    return `✓ Tu visita del ${fechaFormateada} ha sido registrada`;
  }
}

async function registrarVisita() {
  if (!validar()) return;
  const btn = $('btn-submit');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Registrando...';
  const ahora = new Date();
  const fechaSeleccionada = $('f-fecha').value.trim();
  const payload = {
    funcionario: SESSION.func,
    aseguradora: SESSION.aseg,
    estado: 'Realizada',
    fecha: fechaSeleccionada,
    horaRegistro: ahora.toTimeString().slice(0, 5),
    modalidad: $('f-modal').value,
    objetivo: $('f-obj').value,
    comerciales: $('f-com').value || '0',
    operativos: $('f-ope').value || '0',
    oficina: oficinaSel.oficina,
    codOficina: oficinaSel.codOficina,
    gerenciaRegional: $('f-regional2').value,
    gerenciaZonal: $('f-zonal2').value
  };
  try {
    const resultado = await enviarYConfirmar(payload);
    if (resultado && resultado.ok) {
      mostrarExito();
      const mensaje = obtenerMensajeExito(fechaSeleccionada);
      showToast(mensaje);
      debugLog('Confirmado en Supabase, id: ' + resultado.id, 'ok');
      limpiarFormulario();
      if (!$('card-calendario').classList.contains('hidden')) {
        await cargarVisitasCalendario();
      }
    } else if (resultado && !resultado.ok) {
      showToast('El servidor reportó un error: ' + resultado.error, true);
      debugLog('Error del servidor: ' + resultado.error, 'err');
    } else {
      showToast('No se pudo contactar al servidor. Revisa tu conexión.', true);
      debugLog('Sin respuesta del servidor', 'err');
    }
  } catch (e) {
    showToast('Error al registrar. Intenta de nuevo.', true);
    debugLog('Error en registrarVisita: ' + (e.message || e), 'err');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="ti ti-send-2"></i> Registrar visita';
  }
}

function limpiarFormulario(){
  oficinaSel = null;
  $('of-search').value = '';
  $('sel-card').className = 'sel-card';
  $('btn-cambiar-oficina').className = 'btn-mini-red hidden';
  poblarRegionales();
  $('f-modal').selectedIndex = 0;
  $('f-obj').selectedIndex = 1;
  $('f-com').value = '';
  $('f-ope').value = '';
  clearError('f-com');
  clearError('f-ope');
  if(fpFecha){ 
    const hoy = new Date();
    fpFecha.setDate(hoy);
    const input = document.getElementById('f-fecha');
    if(input) {
      input.value = fpFecha.formatDate(hoy, 'Y-m-d');
    }
    fechaConfirmada = obtenerFechaHoyStr();
  }
  actualizarProgreso();
}

function toggleCalendario() {
  const card = $('card-calendario');
  const estaOculto = card.classList.contains('hidden');
  if (estaOculto) {
    card.classList.remove('hidden');
    card.style.display = 'block';
    cargarVisitasCalendario();
    setTimeout(() => {
      card.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 300);
  } else {
    ocultarCalendario();
  }
}

function ocultarCalendario() {
  const card = $('card-calendario');
  card.classList.add('hidden');
  card.style.display = 'none';
  diaSeleccionado = null;
}

function aplicarFiltro(filtro) {
  filtroActivo = filtro;
  document.querySelectorAll('.cal-filtro').forEach(btn => {
    btn.classList.toggle('activo', btn.dataset.filtro === filtro);
  });
  renderizarCalendario();
  if (diaSeleccionado) {
    const [a, m, d] = diaSeleccionado.split('-').map(Number);
    verDetalleDia(a, m-1, d);
  }
}

function obtenerVisitasFiltradas() {
  if (filtroActivo === 'todos') return visitasCache;
  return visitasCache.filter(v => v.modalidad === filtroActivo);
}

function renderizarCalendario() {
  const año = calFecha.getFullYear();
  const mes = calFecha.getMonth();
  const nombresMeses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  
  const visitasMes = obtenerVisitasFiltradas().filter(v => {
    if (!v.fecha) return false;
    const f = new Date(v.fecha + 'T00:00:00');
    return f.getFullYear() === año && f.getMonth() === mes;
  });
  
  document.getElementById('cal-titulo').textContent = nombresMeses[mes] + ' ' + año;
  document.getElementById('cal-titulo-count').textContent = 
    visitasMes.length + ' visita' + (visitasMes.length === 1 ? '' : 's') + ' este mes';
  
  const diasSemana = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
  let html = diasSemana.map(d => `<div style="font-weight:700;color:var(--t2);padding:8px 0;font-size:11px;text-transform:uppercase;letter-spacing:.3px">${d}</div>`).join('');
  
  let primerDia = new Date(año, mes, 1).getDay();
  primerDia = primerDia === 0 ? 6 : primerDia - 1;
  const diasEnMes = new Date(año, mes + 1, 0).getDate();
  const diasEnMesAnt = new Date(año, mes, 0).getDate();
  
  for (let i = diasEnMesAnt - primerDia + 1; i <= diasEnMesAnt; i++) {
    html += `<div class="cal-dia otro-mes"><span class="dia-num">${i}</span></div>`;
  }
  
  const hoy = new Date();
  const hoyStr = hoy.toDateString();
  const visitasPorDia = {};
  visitasMes.forEach(v => {
    if (v.fecha) {
      const fecha = new Date(v.fecha + 'T00:00:00');
      if (fecha.getFullYear() === año && fecha.getMonth() === mes) {
        const key = fecha.getDate();
        if (!visitasPorDia[key]) visitasPorDia[key] = [];
        visitasPorDia[key].push(v);
      }
    }
  });
  
  for (let dia = 1; dia <= diasEnMes; dia++) {
    const fecha = new Date(año, mes, dia);
    const esHoy = fecha.toDateString() === hoyStr;
    const tieneVisita = visitasPorDia[dia] && visitasPorDia[dia].length > 0;
    const numVisitas = tieneVisita ? visitasPorDia[dia].length : 0;
    
    let clases = 'cal-dia';
    if (esHoy) clases += ' hoy';
    if (tieneVisita) clases += ' con-visita';
    
    const fechaStr = `${año}-${String(mes+1).padStart(2,'0')}-${String(dia).padStart(2,'0')}`;
    if (diaSeleccionado === fechaStr) clases += ' seleccionado';
    
    let punto = '';
    if (tieneVisita) {
      punto = numVisitas > 1 
        ? `<span class="dia-punto multiple"></span>` 
        : `<span class="dia-punto"></span>`;
    }
    
    html += `<div class="${clases}" onclick="verDetalleDia(${año}, ${mes}, ${dia})">
      <span class="dia-num">${dia}</span>
      ${punto}
    </div>`;
  }
  
  const totalDias = primerDia + diasEnMes;
  const sobrantes = totalDias % 7 === 0 ? 0 : 7 - (totalDias % 7);
  for (let i = 1; i <= sobrantes; i++) {
    html += `<div class="cal-dia otro-mes"><span class="dia-num">${i}</span></div>`;
  }
  
  document.getElementById('cal-grid').innerHTML = html;
}

function cambiarMes(delta) {
  calFecha.setMonth(calFecha.getMonth() + delta);
  diaSeleccionado = null;
  document.getElementById('cal-detalle').style.display = 'none';
  renderizarCalendario();
}

function irHoy() {
  calFecha = new Date();
  diaSeleccionado = null;
  document.getElementById('cal-detalle').style.display = 'none';
  renderizarCalendario();
}

function verDetalleDia(año, mes, dia) {
  const fechaStr = `${año}-${String(mes+1).padStart(2,'0')}-${String(dia).padStart(2,'0')}`;
  diaSeleccionado = fechaStr;
  
  renderizarCalendario();
  
  const visitas = obtenerVisitasFiltradas().filter(v => v.fecha === fechaStr);
  const nombresMeses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const fechaObj = new Date(año, mes, dia);
  const diasSemana = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];
  const nombreDia = diasSemana[fechaObj.getDay()];
  
  const detalle = document.getElementById('cal-detalle');
  
  if (visitas.length === 0) {
    detalle.innerHTML = `
      <div class="cal-detalle">
        <div class="cal-detalle-header">
          <h4><i class="ti ti-calendar-off"></i> ${nombreDia.charAt(0).toUpperCase() + nombreDia.slice(1)}, ${dia} de ${nombresMeses[mes]}</h4>
          <span class="badge-count">0 visitas</span>
        </div>
        <div class="dia-sin-visitas">
          <i class="ti ti-calendar-x"></i>
          No hay visitas registradas este día
        </div>
      </div>
    `;
  } else {
    const totalComerciales = visitas.reduce((sum, v) => sum + (parseInt(v.comerciales) || 0), 0);
    const totalOperativos = visitas.reduce((sum, v) => sum + (parseInt(v.operativos) || 0), 0);
    
    const visitasHTML = visitas.map(v => `
      <div class="detalle-item">
        <div class="detalle-item-top">
          <span class="aseg-badge">${v.aseguradora || 'N/A'}</span>
          <span class="ofi"><i class="ti ti-building"></i> ${v.oficina || 'Sin oficina'}</span>
          <span class="hora"><i class="ti ti-clock"></i> ${v.hora_registro || '--:--'}</span>
        </div>
        <div class="detalle-item-details">
          <div class="detail-row">
            <i class="ti ti-target"></i>
            <span><strong>${v.objetivo || 'N/A'}</strong></span>
          </div>
          <div class="detail-row">
            <i class="ti ti-${v.modalidad === 'Virtual' ? 'video' : 'walk'}"></i>
            <span>${v.modalidad || 'N/A'}</span>
          </div>
          <div class="detail-row">
            <i class="ti ti-map"></i>
            <span>${v.gerencia_regional || 'N/A'}</span>
          </div>
          <div class="detail-row">
            <i class="ti ti-layers"></i>
            <span>${v.gerencia_zonal || 'N/A'}</span>
          </div>
        </div>
        <div class="detalle-item-stats">
          <span class="stat-chip"><i class="ti ti-users"></i> ${v.comerciales || 0} Comerciales</span>
          <span class="stat-chip"><i class="ti ti-user"></i> ${v.operativos || 0} Operativos</span>
          ${v.estado ? `<span class="stat-chip"><i class="ti ti-check"></i> ${v.estado}</span>` : ''}
        </div>
      </div>
    `).join('');
    
    detalle.innerHTML = `
      <div class="cal-detalle">
        <div class="cal-detalle-header">
          <h4><i class="ti ti-calendar-event"></i> ${nombreDia.charAt(0).toUpperCase() + nombreDia.slice(1)}, ${dia} de ${nombresMeses[mes]}</h4>
          <span class="badge-count">${visitas.length} visita${visitas.length > 1 ? 's' : ''}</span>
        </div>
        <div class="cal-detalle-lista">
          ${visitasHTML}
        </div>
      </div>
    `;
  }
  
  detalle.style.display = 'block';
  setTimeout(() => {
    detalle.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }, 100);
}

async function cargarVisitasCalendario() {
  if (!SESSION) return;
  
  try {
    const resp = await fetch(SUPABASE_URL + '/rest/v1/rpc/obtener_visitas_funcionario', {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ p_funcionario: SESSION.func })
    });
    if (!resp.ok) throw new Error('Error al cargar visitas');
    const data = await resp.json();
    visitasCache = data || [];
    renderizarCalendario();
  } catch (err) {
    console.error('Error cargando visitas:', err);
    const grid = document.getElementById('cal-grid');
    if (grid) {
      grid.innerHTML = `<div style="grid-column:1/-1;padding:30px;text-align:center;color:var(--t3)">
        <i class="ti ti-database-off" style="font-size:30px;display:block;margin-bottom:10px"></i>
        No se pudieron cargar las visitas. Intenta de nuevo más tarde.
      </div>`;
    }
  }
}

document.addEventListener('DOMContentLoaded', function(){
  fechaConfirmada = obtenerFechaHoyStr();
  
  fpFecha = flatpickr('#f-fecha', {
    dateFormat: 'Y-m-d', 
    locale: 'es', 
    defaultDate: 'today', 
    allowInput: true,
    maxDate: 'today',
    onChange: async function(selectedDates, dateStr, instance){
      clearError('f-fecha');
      if(!selectedDates[0]){ 
        actualizarProgreso(); 
        return; 
      }
      const hoy = new Date(); 
      hoy.setHours(0,0,0,0);
      const elegida = new Date(selectedDates[0]); 
      elegida.setHours(0,0,0,0);
      if(elegida < hoy){
        const ok = await confirmarFechaPasada(dateStr);
        if(!ok){ 
          instance.setDate(fechaConfirmada, false); 
          actualizarProgreso(); 
          return; 
        }
      }
      fechaConfirmada = dateStr;
      actualizarProgreso();
    }
  });

  document.getElementById('f-modal').addEventListener('change', function() {
    // Re-validar los campos numéricos
    validarNumEntrada('f-com');
    validarNumEntrada('f-ope');
    const modalidad = this.value;
    const msgCom = document.getElementById('err-com');
    const msgOpe = document.getElementById('err-ope');
    
    if(modalidad === 'Virtual') {
      msgCom.textContent = 'Solo números, máximo 3 dígitos (1 a 100)';
      msgOpe.textContent = 'Solo números, máximo 3 dígitos (1 a 100)';
    } else {
      msgCom.textContent = 'Solo números, máximo 2 dígitos (1 a 20)';
      msgOpe.textContent = 'Solo números, máximo 2 dígitos (1 a 20)';
    }
  });
  
  const ofInput = $('of-search');
  ofInput.addEventListener('input', ()=>buscarOficina(false));
  ofInput.addEventListener('focus', function(){
    if(this.disabled) return;
    buscarOficina(true);
    this.select();
  });
  ofInput.addEventListener('keydown', function(e){
    const box = $('of-results');
    if(!box.classList.contains('show')) return;
    const opts = box.querySelectorAll('.of-opt[data-pos]');
    if(!opts.length) return;
    if(e.key === 'ArrowDown'){ 
      e.preventDefault(); 
      ofActiveIdx = Math.min(ofActiveIdx+1, opts.length-1); 
      resaltarOpt(opts); 
    }
    else if(e.key === 'ArrowUp'){ 
      e.preventDefault(); 
      ofActiveIdx = Math.max(ofActiveIdx-1, 0); 
      resaltarOpt(opts); 
    }
    else if(e.key === 'Enter'){ 
      e.preventDefault(); 
      if(ofActiveIdx >= 0) opts[ofActiveIdx].click(); 
    }
    else if(e.key === 'Escape'){ 
      box.className = 'of-results'; 
    }
  });
  
  document.addEventListener('click', function(e){
    if(!e.target.closest('#of-search') && !e.target.closest('#of-results')){
      $('of-results').className = 'of-results';
    }
  });
  
  cargarOficinas();
  cargarFuncionarios();
  
  const saved = localStorage.getItem('rv_session');
  if(saved){
    try{
      SESSION = JSON.parse(saved);
      mostrarFormulario();
    }catch(e){
      debugLog('Error al restaurar sesión', 'err');
    }
  }
});
</script>
